{
  "name": "pr-review-agent",
  "version": "0.1.0",
  "description": "GitAgent definition: policy-aware PR review (gitclaw runtime)",
  "private": true,
  "type": "module",
  "scripts": {
    "validate": "node scripts/validate-structure.mjs",
    "validate:gitagent": "gitagent validate",
    "info": "gitagent info",
    "export:prompt": "gitagent export -f system-prompt",
    "heuristics": "node scripts/local-heuristics.mjs",
    "gitclaw:help": "dotenv -e .env -- gitclaw --help",
    "demo": "node scripts/run-demo.mjs",
    "review:claude": "node scripts/run-provider-review.mjs claude",
    "review:gpt": "node scripts/run-provider-review.mjs gpt",
    "review:gemini": "node scripts/run-provider-review.mjs gemini",
    "review:auto": "node scripts/run-provider-review.mjs",
    "dashboard": "node scripts/dashboard-server.mjs",
    "ml:analyze": "node scripts/ml-anomaly-detection.mjs"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "optionalDependencies": {
    "@anthropic-ai/sdk": "^0.28.0",
    "openai": "^4.82.0",
    "@google/generative-ai": "^0.21.0"
  },
  "devDependencies": {
    "@open-gitagent/gitagent": "^0.1.8",
    "dotenv-cli": "^8.0.0",
    "gitclaw": "^1.1.8"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
