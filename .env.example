# PR Review Agent - Environment Variables
# Copy this file to .env and add your actual API keys (never commit .env to git)

# Anthropic API Key (required for gitclaw with Claude models)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: OpenAI API Key (if using fallback models)
# OPENAI_API_KEY=sk-your-openai-key-here

# Optional: Logging level
# LOG_LEVEL=info
